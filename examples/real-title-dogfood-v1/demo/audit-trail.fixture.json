  "stageAudit": [
    { "stage": "detect", "ledgerEvent": "dogfood.campaign.stage.completed", "evidenceRefs": ["ledger.jsonl", "journal.md", "verdict.json"] },
    { "stage": "explain", "ledgerEvent": "dogfood.campaign.stage.completed", "evidenceRefs": ["ledger.jsonl", "journal.md", "verdict.json"] },
    { "stage": "trace", "ledgerEvent": "dogfood.campaign.stage.completed", "evidenceRefs": ["ledger.jsonl", "journal.md", "verdict.json"] },
    { "stage": "attribute", "ledgerEvent": "dogfood.campaign.stage.completed", "evidenceRefs": ["ledger.jsonl", "journal.md", "verdict.json", "examples/real-title-dogfood-v1/refs/loop-coverage-attribution.json"] },
    { "stage": "propose", "ledgerEvent": "dogfood.campaign.stage.completed", "evidenceRefs": ["ledger.jsonl", "journal.md", "verdict.json", "examples/real-title-dogfood-v1/refs/promotion-rollback-record.json"] },
    { "stage": "re-verify", "ledgerEvent": "dogfood.campaign.stage.completed", "evidenceRefs": ["ledger.jsonl", "journal.md", "verdict.json", "examples/real-title-dogfood-v1/refs/validation-result.json"] },
    { "stage": "apply-or-queue", "ledgerEvent": "dogfood.campaign.stage.completed", "evidenceRefs": ["ledger.jsonl", "journal.md", "verdict.json", "examples/real-title-dogfood-v1/refs/promotion-rollback-record.json"] }
  ],
  "pipelineRefs": [
    "openchrome",
    "scenario-verdicts",
    "four-gates",
    "design-integrity",
    "journal.md",
    "ledger.jsonl",
    "loop-coverage-attribution",
    "evolve",
    "source-apply",
    "trust-gradient"
  ],
  "highRiskAutoApply": false,
  "sourceAffectingAutoApply": false,
  "newVerificationEngine": false,
  "newDataPlane": false,
  "boundary": "Audit trail links demo stages to existing evidence artifacts only; source-affecting/high-risk changes remain queued for thin human go/no-go and fun/taste plus release go/no-go remain Ring 2."
