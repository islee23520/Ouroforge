{
  "schemaVersion": "scenario-pack-v1",
  "id": "gameplay-logic-demo",
  "description": "Structured gameplay logic demo scenario pack for key, door, dash, patrol hazard, and win-condition behavior without arbitrary scripts.",
  "seed": "seeds/gameplay-logic-demo.yaml",
  "scenes": [
    "scenes/gameplay-logic-demo.scene.json"
  ],
  "scenarioGroups": [
    {
      "id": "structured-behavior-outcomes",
      "description": "Scenario placeholders tied to behavior assertion evidence generated by the Rust/local behavior runtime.",
      "scenarios": [
        {
          "id": "collect-key",
          "description": "Key pickup is represented by structured collectItem and emitted-event evidence.",
          "steps": [
            {
              "input": {
                "actions": {
                  "keyPickup": true
                }
              }
            }
          ],
          "assertions": [
            {
              "world_state": {
                "path": "inventory.key",
                "exists": true
              }
            },
            {
              "runtime_events": {
                "path": "events",
                "containsType": "keyCollected"
              }
            }
          ]
        },
        {
          "id": "open-door-and-exit",
          "description": "Door unlock and exit win condition are gated by inventory/flag evidence.",
          "steps": [
            {
              "input": {
                "actions": {
                  "doorReached": true
                }
              }
            },
            {
              "input": {
                "actions": {
                  "exitReached": true
                }
              }
            }
          ],
          "assertions": [
            {
              "world_flags": {
                "equals": true,
                "path": "flags.doorOpen"
              }
            },
            {
              "runtime_events": {
                "path": "events",
                "containsType": "victory"
              }
            }
          ]
        },
        {
          "id": "dash-and-patrol",
          "description": "Dash ability and patrol hazard produce bounded movement, state transition, and health evidence.",
          "steps": [
            {
              "input": {
                "actions": {
                  "dash": true
                }
              }
            },
            {
              "wait": {
                "frames": 8
              }
            }
          ],
          "assertions": [
            {
              "world_state": {
                "path": "entityPositions.player",
                "exists": true
              }
            },
            {
              "runtime_events": {
                "path": "events",
                "containsType": "patrolHazard"
              }
            }
          ]
        }
      ]
    }
  ]
}
