{
  "schemaVersion": "scenario-pack-v1",
  "id": "collect-and-exit",
  "description": "Playable Demo v2 collect-and-exit source fixture scenario pack.",
  "seed": "seeds/collect-and-exit.yaml",
  "scenes": [
    "scenes/collect-and-exit.scene.json"
  ],
  "scenarioGroups": [
    {
      "id": "source-contract",
      "description": "Bounded source/evidence contracts for the one-screen playable demo.",
      "scenarios": [
        {
          "id": "collect-key-hud-contract",
          "description": "The demo reaches collected-key and exit evidence with HUD, animation, and audio intent.",
          "assertions": [
            {
              "world_state": {
                "path": "sceneId",
                "equals": "collect-and-exit-scene"
              }
            },
            {
              "world_state": {
                "path": "componentModel.hudValues",
                "exists": true
              }
            },
            {
              "world_state": {
                "path": "goalFlags.key_collected",
                "equals": true
              }
            },
            {
              "world_state": {
                "path": "goalFlags.exit_reached",
                "equals": true
              }
            },
            {
              "animation_evidence": {
                "path": "0.mode",
                "equals": "sprite_frame"
              }
            },
            {
              "audio_evidence": {
                "path": "0.name",
                "equals": "player_spawn"
              }
            },
            {
              "world_state": {
                "path": "metadata.title",
                "equals": "Collect and Exit Vertical Slice Demo"
              }
            },
            {
              "world_state": {
                "path": "metadata.startState.checkpointSlot",
                "equals": "demo-start"
              }
            },
            {
              "frame_stats": {
                "path": "runtimeFrameBudgetStatus",
                "equals": "within-budget"
              }
            },
            {
              "runtime_events": {
                "path": "events",
                "containsType": "runtime.save.loaded"
              }
            }
          ]
        }
      ]
    }
  ]
}
