    {
      "name": "applies entity transform x and y atomically",
      "delta": {
        "schemaVersion": "ouroforge.preview-delta.v1",
        "deltaId": "preview-delta-fixture-001",
        "sessionId": "fixture-session",
        "intentId": "fixture-intent-001",
        "sequence": 1,
        "kind": "entityTransform",
        "status": "applied",
        "edits": [
          { "entityId": "player", "path": "components.transform.x", "value": 48 },
          { "entityId": "player", "path": "components.transform.y", "value": 96 }
        ],
        "beforeSceneHash": { "algorithm": "fnv1a64", "value": "0" },
        "afterSceneHash": { "algorithm": "fnv1a64", "value": "1" }
      },
      "expect": {
        "ok": true,
        "appliedEdits": 2,
        "worldChecks": [
          { "entityId": "player", "path": "components.transform.x", "value": 48 },
          { "entityId": "player", "path": "components.transform.y", "value": 96 }
        ]
      }
    },
