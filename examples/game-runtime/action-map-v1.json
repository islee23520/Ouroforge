{
  "schemaVersion": "1",
  "id": "action-map-v1-fixture",
  "bounds": { "width": 320, "height": 180 },
  "entities": [
    {
      "id": "player",
      "sprite": { "color": "#5eead4" },
      "components": {
        "transform": { "x": 32, "y": 72 },
        "velocity": { "x": 0, "y": 0 },
        "size": { "width": 16, "height": 16 },
        "controllable": true,
        "input": {
          "scheme": "keyboard",
          "moveSpeed": 3,
          "jumpImpulse": 6,
          "allowedActions": ["move_left", "move_right", "jump", "interact"],
          "actionMap": {
            "actions": [
              {
                "id": "move_left",
                "keyboard": ["left", "a"],
                "gamepad": {
                  "buttons": ["dpad_left"],
                  "axes": [{ "axis": "left_x", "direction": "negative" }]
                }
              },
              {
                "id": "move_right",
                "keyboard": ["right", "d"],
                "gamepad": {
                  "buttons": ["dpad_right"],
                  "axes": [{ "axis": "left_x", "direction": "positive" }]
                }
              },
              { "id": "jump", "keyboard": ["space", "up"], "gamepad": { "buttons": ["south"] } },
              { "id": "interact", "keyboard": ["e"] }
            ]
          }
        }
      }
    }
  ]
}
