{
  "schemaVersion": "ouroforge.behavior-artifact.v1",
  "artifactId": "behavior-runtime-execution-demo",
  "sceneId": "scene-runtime-demo",
  "validatedBy": {
    "authority": "ouroforge-rust-local-validator",
    "validationStatus": "passed",
    "reviewDecisionId": "review-gl10-7-2"
  },
  "behaviors": [
    {
      "id": "player-jump",
      "entityId": "player",
      "triggers": [{ "id": "jump-input", "kind": "onInputAction", "event": "jump" }],
      "conditions": [{ "id": "grounded", "kind": "flagEquals", "field": "grounded", "value": "true" }],
      "actions": [
        { "id": "mark-jumped", "kind": "setFlag", "effectKind": "flag", "flag": "jumped" },
        { "id": "jump-motion", "kind": "moveEntity", "effectKind": "movement", "targetEntityId": "player", "dx": 0, "dy": -2 },
        { "id": "jump-audio", "kind": "startAudioIntent", "effectKind": "audioIntent", "value": "jump" }
      ],
      "stateMachine": {
        "initialState": "idle",
        "states": [
          { "id": "idle", "transitions": [{ "id": "begin-jump", "to": "airborne", "onEvent": "jumped" }] },
          { "id": "airborne", "transitions": [{ "id": "land", "to": "idle", "onEvent": "landed" }] }
        ]
      }
    },
    {
      "id": "goal-finish",
      "entityId": "goal",
      "triggers": [{ "id": "goal-event", "kind": "onEvent", "event": "goalReached" }],
      "conditions": [{ "id": "has-key", "kind": "hasItem", "value": "key" }],
      "actions": [
        { "id": "win", "kind": "markWinState", "effectKind": "terminalState" },
        { "id": "victory-event", "kind": "emitEvent", "effectKind": "event", "event": "victory" }
      ]
    }
  ]
}
