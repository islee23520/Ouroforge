{
  "schemaVersion": "ouroforge.behavior-artifact.v1",
  "artifactId": "behavior-runtime-demo",
  "sceneId": "scene-runtime-demo",
  "validatedBy": {
    "authority": "ouroforge-rust-local-validator",
    "validationStatus": "passed",
